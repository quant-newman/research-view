# 复制为 .env 并填值。.env 不入 git。
# --- LLM ---
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- 数据节点 SSH(仅编排节点运维用)---
ALIYUN_DC_HOST=x.x.x.x
ALIYUN_DC_USER=user
ALIYUN_DC_PASS=xxx

# --- 数据源 ---
TUSHARE_TOKEN=xxx

# --- PostgreSQL(数据节点本机 127.0.0.1,采集侧运行时用)---
# 本项目独立库(读写)
RESEARCH_VIEW_DSN=postgresql://rv_rw:PASS@127.0.0.1:5432/research_view
# 数据中心行情库(只读,rv_rw 在 DB 层无写权限)
MARKETDATA_RO_DSN=postgresql://rv_rw:PASS@127.0.0.1:5432/marketdata
RV_DB_PASS=xxx

# --- X/Twitter 舆情(可选,编排节点侧)---
X_AUTH_TOKEN=xxx
X_CT0=xxx

# --- 校准期冻结(DECISIONS #28)---
# 默认冻结(不配=1):B7 lessons 只落库不注入发卡 prompt,防首批校准样本口径漂移。
# 解冻(首份周报+样本≥40 后使用者拍板)显式设 0,并记 DECISIONS。
# CALIBRATION_FREEZE=1
